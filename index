<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Edge · Sports Intelligence</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-font-smoothing:antialiased}
:root{
  --black:#05070d;--bg1:#090d18;--bg2:#0e1425;--bg3:#131b30;--bg4:#192038;--bg5:#1f2842;
  --line:rgba(255,255,255,.07);--line2:rgba(255,255,255,.12);
  --t1:#f0f4ff;--t2:#8895b0;--t3:#4a5670;
  --g:#00e676;--gd:rgba(0,230,118,.08);--gb:rgba(0,230,118,.22);
  --b:#4d8bff;--bd:rgba(77,139,255,.08);--bb:rgba(77,139,255,.22);
  --a:#ffb020;--ad:rgba(255,176,32,.08);--ab:rgba(255,176,32,.22);
  --r:#ff4d4d;--rd:rgba(255,77,77,.08);--rb:rgba(255,77,77,.22);
  --p:#b06dff;
}
html,body{background:var(--black);color:var(--t1);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:14px;min-height:100vh}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-thumb{background:var(--bg5);border-radius:4px}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.65)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
@keyframes slideRight{from{opacity:0;transform:translateX(-8px)}to{opacity:1;transform:translateX(0)}}
@keyframes spin{to{transform:rotate(360deg)}}

.shell{width:100%;max-width:1000px;margin:0 auto;padding:0 20px}

/* TOPBAR */
.topbar{padding:20px 0 0;display:flex;align-items:center;justify-content:space-between;gap:16px}
.logo{display:flex;align-items:center;gap:10px}
.logo-mark{width:32px;height:32px;background:linear-gradient(135deg,var(--b),var(--p));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;color:#fff;flex-shrink:0}
.logo-text{font-size:18px;font-weight:800;letter-spacing:-.4px;background:linear-gradient(90deg,var(--t1),var(--t2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.logo-sub{font-size:10px;color:var(--t3);font-weight:500;margin-top:1px}
.topbar-right{display:flex;align-items:center;gap:8px}
.status-pill{display:flex;align-items:center;gap:6px;padding:6px 12px;background:var(--bg2);border:1px solid var(--line2);border-radius:20px;font-size:11px;font-weight:600;color:var(--t2)}
.status-dot{width:6px;height:6px;border-radius:50%;background:var(--g);animation:pulse 2s infinite;flex-shrink:0}
.status-dot.loading{background:var(--a)}
.rfsh-btn{display:flex;align-items:center;gap:6px;padding:7px 14px;background:var(--bg3);border:1px solid var(--line2);border-radius:10px;color:var(--t1);font-size:12px;font-weight:600;cursor:pointer;transition:all .15s;font-family:inherit}
.rfsh-btn:hover{background:var(--bg4);border-color:var(--b);color:var(--b)}
.rfsh-btn:disabled{opacity:.5;cursor:default}

/* DATE BAR */
.datebar{padding:14px 0 0;display:flex;align-items:center;justify-content:space-between}
.date-label{font-size:13px;color:var(--t2);font-weight:500}
.date-label span{color:var(--t1);font-weight:700}
.sport-badges{display:flex;gap:5px}
.sb-live{font-size:10px;font-weight:700;padding:3px 8px;border-radius:6px;background:var(--gd);border:1px solid var(--gb);color:var(--g)}
.sb-off{font-size:10px;font-weight:700;padding:3px 8px;border-radius:6px;background:rgba(255,255,255,.04);border:1px solid var(--line);color:var(--t3)}

/* TABS */
.tab-bar{padding:18px 0 0;border-bottom:1px solid var(--line);display:flex;overflow-x:auto}
.tab-bar::-webkit-scrollbar{display:none}
.tab-btn{display:flex;align-items:center;gap:6px;padding:9px 16px 11px;background:transparent;border:none;color:var(--t3);font-size:12px;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;white-space:nowrap;font-family:inherit;transition:color .15s}
.tab-btn:hover{color:var(--t2)}
.tab-btn.on{color:var(--t1);font-weight:700;border-bottom-color:var(--b)}
.tab-btn .tdot{width:5px;height:5px;border-radius:50%;background:var(--t3);flex-shrink:0}
.tdot.live{background:var(--g) !important}
.tab-badge{font-size:9px;font-weight:800;padding:1px 5px;border-radius:8px;background:var(--ad);border:1px solid var(--ab);color:var(--a)}

/* CONTENT */
.content{padding:24px 0;animation:fadeUp .25s ease}

/* KPI STRIP */
.kpi-strip{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:24px}
@media(max-width:600px){.kpi-strip{grid-template-columns:repeat(2,1fr)}}
.kpi-card{background:var(--bg2);border:1px solid var(--line);border-radius:14px;padding:16px;position:relative;overflow:hidden}
.kpi-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:14px 14px 0 0}
.kc-g::before{background:linear-gradient(90deg,var(--g),transparent)}
.kc-b::before{background:linear-gradient(90deg,var(--b),transparent)}
.kc-a::before{background:linear-gradient(90deg,var(--a),transparent)}
.kc-r::before{background:linear-gradient(90deg,var(--r),transparent)}
.kpi-label{font-size:10px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px}
.kpi-value{font-size:30px;font-weight:900;line-height:1;letter-spacing:-.8px;margin-bottom:4px}
.kpi-sub{font-size:10px;color:var(--t3);font-weight:500}
.kv-g{color:var(--g)}.kv-b{color:var(--b)}.kv-a{color:var(--a)}.kv-r{color:var(--r)}.kv-w{color:var(--t1)}

/* SECTION HEADER */
.sec-hd{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.sec-hd-text{font-size:11px;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:.08em;white-space:nowrap}
.sec-hd-line{flex:1;height:1px;background:var(--line)}

/* GAME CARD */
.game-card{background:var(--bg2);border:1px solid var(--line);border-radius:16px;margin-bottom:10px;overflow:hidden;cursor:pointer;transition:all .18s;animation:slideRight .2s ease}
.game-card:hover{background:var(--bg3);border-color:var(--line2);transform:translateY(-1px);box-shadow:0 4px 24px rgba(0,0,0,.4)}
.game-card.sig-strong{border-left:3px solid var(--g)}
.game-card.sig-lean{border-left:3px solid var(--b)}
.game-card.sig-fade{border-left:3px solid var(--r)}
.game-card.sig-neutral{border-left:3px solid var(--t3)}
.gc-top{display:grid;grid-template-columns:1fr auto;gap:12px;padding:16px 18px;align-items:start}
.gc-teams{font-size:15px;font-weight:700;margin-bottom:6px;display:flex;align-items:center;gap:4px;flex-wrap:wrap;letter-spacing:-.2px}
.gc-away{color:var(--t2);font-weight:500}
.gc-vs{color:var(--t3);font-size:12px;margin:0 4px}
.gc-home{color:var(--t1)}
.gc-meta{display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.gc-time{font-size:11px;color:var(--t2)}
.gc-sep{width:3px;height:3px;border-radius:50%;background:var(--t3);flex-shrink:0}
.gc-chip{font-size:9px;font-weight:700;padding:2px 7px;border-radius:5px;background:rgba(255,255,255,.05);color:var(--t2);text-transform:uppercase}
.playoff-chip{background:var(--ad);border:1px solid var(--ab);color:var(--a)}
.gc-right{text-align:right}
.sig-badge{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:800;padding:4px 11px;border-radius:20px;margin-bottom:7px;letter-spacing:.03em}
.sig-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.sig-strong-b{background:var(--gd);border:1px solid var(--gb);color:var(--g)}
.sig-lean-b{background:var(--bd);border:1px solid var(--bb);color:var(--b)}
.sig-fade-b{background:var(--rd);border:1px solid var(--rb);color:var(--r)}
.sig-neutral-b{background:rgba(255,255,255,.04);border:1px solid var(--line);color:var(--t2)}
.gc-rec{font-size:14px;font-weight:800;color:var(--t1);margin-bottom:5px;letter-spacing:-.2px}
.conf-row{display:flex;align-items:center;gap:6px;justify-content:flex-end}
.conf-track{width:58px;height:3px;background:rgba(255,255,255,.07);border-radius:2px}
.conf-fill{height:3px;border-radius:2px;transition:width .5s ease}
.conf-pct{font-size:10px;color:var(--t2);font-weight:700}
.gc-body{border-top:1px solid var(--line);padding:14px 18px;background:rgba(0,0,0,.25);display:none}
.gc-body.open{display:block;animation:fadeUp .15s ease}
.pitcher-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.pitcher-box{background:var(--bg3);border:1px solid var(--line);border-radius:10px;padding:10px 12px}
.pitcher-lbl{font-size:9px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px}
.pitcher-name{font-size:12px;font-weight:700;color:var(--t1)}
.series-pill{display:inline-flex;align-items:center;font-size:11px;font-weight:600;color:var(--a);background:var(--ad);border:1px solid var(--ab);border-radius:6px;padding:4px 9px;margin-bottom:10px}
.gc-analysis{font-size:12px;color:var(--t2);line-height:1.75;margin-bottom:11px}
.injury-item{display:flex;align-items:flex-start;gap:7px;font-size:11px;color:var(--r);background:var(--rd);border:1px solid var(--rb);border-radius:7px;padding:7px 10px;margin-bottom:5px}
.factor-row{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:11px}
.factor-tag{font-size:10px;font-weight:600;padding:3px 9px;border-radius:8px}
.ft-pos{background:var(--gd);border:1px solid var(--gb);color:var(--g)}
.ft-neg{background:var(--rd);border:1px solid var(--rb);color:var(--r)}
.line-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;padding-top:12px;border-top:1px solid var(--line)}
.line-box{background:var(--bg4);border-radius:9px;padding:9px;text-align:center}
.line-lbl{font-size:9px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.line-val{font-size:14px;font-weight:800;color:var(--t1)}
.line-val.blue{color:var(--b)}

/* BEST BETS HERO */
.bb-hero{background:linear-gradient(135deg,rgba(77,139,255,.08),rgba(176,109,255,.05));border:1px solid rgba(77,139,255,.16);border-radius:18px;padding:18px;margin-bottom:24px}
.bb-hero-hd{font-size:11px;font-weight:800;color:var(--b);text-transform:uppercase;letter-spacing:.09em;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.bb-hero-hd::after{content:'';flex:1;height:1px;background:rgba(77,139,255,.2)}
.bb-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(158px,1fr));gap:8px}
.bb-item{background:rgba(0,0,0,.3);border:1px solid var(--line);border-radius:11px;padding:12px;cursor:pointer;transition:all .15s}
.bb-item:hover{background:rgba(255,255,255,.04);transform:translateY(-1px)}
.bb-pick{font-size:13px;font-weight:800;color:var(--t1);margin-bottom:3px}
.bb-detail{font-size:10px;color:var(--t2);margin-bottom:8px;line-height:1.4}
.bb-foot{display:flex;justify-content:space-between;align-items:center}

/* INJURY BANNER */
.injury-banner{background:var(--rd);border:1px solid var(--rb);border-radius:12px;padding:12px 15px;margin-bottom:18px}
.inj-hd{font-size:10px;font-weight:800;color:var(--r);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px}
.inj-item{font-size:11px;color:rgba(255,140,140,.9);padding:4px 0;border-bottom:1px solid var(--rb)}
.inj-item:last-child{border-bottom:none}

/* TRACKER */
.tracker-kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:22px}
@media(max-width:580px){.tracker-kpis{grid-template-columns:repeat(3,1fr)}}
.tkpi{background:var(--bg2);border:1px solid var(--line);border-radius:14px;padding:16px;text-align:center}
.tkpi-v{font-size:28px;font-weight:900;letter-spacing:-.6px;margin-bottom:3px}
.tkpi-l{font-size:9px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.07em}
.model-insight{background:linear-gradient(90deg,rgba(77,139,255,.07),rgba(176,109,255,.04));border:1px solid rgba(77,139,255,.18);border-radius:12px;padding:13px 16px;margin-bottom:18px;font-size:12px;color:#93c5fd;line-height:1.7}
.model-insight strong{color:var(--b);font-weight:800}
.acc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(134px,1fr));gap:8px;margin-bottom:18px}
.acc-card{background:var(--bg2);border:1px solid var(--line);border-radius:12px;padding:13px}
.acc-pct{font-size:26px;font-weight:900;letter-spacing:-.5px;margin:6px 0 3px}
.acc-sub{font-size:10px;color:var(--t2)}
.pending-item{background:var(--bg2);border:1px solid var(--line);border-radius:10px;padding:12px 14px;display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
.pi-pick{font-size:12px;font-weight:800;color:var(--t1);margin-bottom:3px}
.pi-meta{font-size:10px;color:var(--t2)}
.waiting{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--t2);font-style:italic}
.chart-card{background:var(--bg2);border:1px solid var(--line);border-radius:14px;padding:16px;margin-bottom:18px}
.chart-hd{font-size:12px;font-weight:700;color:var(--t1);margin-bottom:13px;display:flex;justify-content:space-between}
.chart-sub{font-size:10px;color:var(--t3)}
.chart-wrap{position:relative;height:150px}
.hist-wrap{overflow-x:auto;border-radius:12px;border:1px solid var(--line)}
.hist-table{width:100%;border-collapse:collapse;font-size:12px;min-width:500px}
.hist-table th{font-size:9px;font-weight:800;color:var(--t2);text-transform:uppercase;letter-spacing:.07em;padding:10px 13px;border-bottom:1px solid var(--line);text-align:left;background:var(--bg3)}
.hist-table td{padding:11px 13px;border-bottom:1px solid rgba(255,255,255,.04);vertical-align:middle}
.hist-table tr:hover td{background:var(--bg3)}
.r-win{color:var(--g);font-weight:800}.r-loss{color:var(--r);font-weight:800}.r-push{color:var(--a);font-weight:700}.r-pend{color:var(--t3);font-style:italic}
.last-graded{font-size:10px;color:var(--t3);display:flex;align-items:center;gap:5px;margin-bottom:16px}
.lg-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}

/* OFFSEASON */
.off-card{background:var(--bg2);border:1px solid var(--line);border-radius:18px;padding:22px}
.off-title{font-size:20px;font-weight:900;letter-spacing:-.4px;margin-bottom:4px}
.off-badge{font-size:10px;font-weight:800;padding:4px 11px;border-radius:20px}
.off-desc{font-size:13px;color:var(--t2);line-height:1.7;margin:14px 0}
.futures-lbl{font-size:10px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:9px}
.futures-wrap{display:flex;flex-wrap:wrap;gap:6px}
.future-pill{font-size:11px;font-weight:600;padding:5px 13px;border-radius:20px;border:1px solid var(--line2);background:rgba(255,255,255,.04);color:var(--t1)}
.future-pill.fav{background:var(--bd);border-color:var(--bb);color:var(--b);font-weight:800}

.toast{position:fixed;bottom:24px;right:24px;font-size:12px;font-weight:700;padding:10px 16px;border-radius:10px;z-index:9999;pointer-events:none;animation:fadeUp .2s ease;transition:opacity .4s;display:flex;align-items:center;gap:7px;backdrop-filter:blur(10px)}
.empty-state{text-align:center;padding:48px 20px;background:var(--bg2);border:1px solid var(--line);border-radius:16px}
.empty-icon{font-size:32px;margin-bottom:12px;opacity:.4}
.empty-title{font-size:14px;font-weight:700;color:var(--t2);margin-bottom:6px}
.empty-sub{font-size:12px;color:var(--t3)}
.disc{font-size:10px;color:var(--t3);margin-top:20px;padding-top:14px;border-top:1px solid var(--line);line-height:1.7}
</style>
</head>
<body>
<div class="shell">
  <div class="topbar">
    <div class="logo">
      <div class="logo-mark">E</div>
      <div>
        <div class="logo-text">Edge</div>
        <div class="logo-sub">Sports Intelligence</div>
      </div>
    </div>
    <div class="topbar-right">
      <div class="status-pill"><span class="status-dot" id="sdot"></span><span id="ts">Loading</span></div>
      <button class="rfsh-btn" onclick="doRefresh()" id="rfsh-btn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3"/></svg>
        Refresh
      </button>
    </div>
  </div>

  <div class="datebar">
    <div class="date-label">Today is <span id="datestr">—</span></div>
    <div class="sport-badges">
      <span class="sb-live">NBA</span><span class="sb-live">MLB</span>
      <span class="sb-live">NHL</span><span class="sb-off">NFL</span><span class="sb-off">Golf</span>
    </div>
  </div>

  <div class="tab-bar" id="tab-bar"></div>
  <div class="content" id="content"></div>
</div>

<div class="toast" id="toast" style="display:none"></div>

<script>
'use strict';

// ── CONFIGURATION ─────────────────────────────────────────────────────────────
// This is set automatically — your Vercel deployment URL
const PROXY_BASE = window.location.origin;

const SK = 'edge_prod_v1';
const NOW = new Date();
const TODAY_ISO = NOW.toISOString().split('T')[0];
const YEST_ISO = new Date(NOW - 86400000).toISOString().split('T')[0];
const TWO_AGO_ISO = new Date(NOW - 172800000).toISOString().split('T')[0];
const TODAY_LABEL = NOW.toLocaleDateString('en-US', { month: 'numeric', day: 'numeric', year: '2-digit' });
const DATE_DISPLAY = NOW.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });

let picks = [], activeTab = 'best', isLoading = false, plChart = null, toastT = null;

// ── STORAGE ───────────────────────────────────────────────────────────────────
function loadS() { try { return JSON.parse(localStorage.getItem(SK) || '{}'); } catch { return {}; } }
function saveS(p) { const s = loadS(); s.picks = p; try { localStorage.setItem(SK, JSON.stringify(s)); } catch {} }

// ── TOAST ─────────────────────────────────────────────────────────────────────
function toast(msg, ok = true) {
  const el = document.getElementById('toast');
  el.innerHTML = `${ok ? '✓' : '!'} ${msg}`;
  el.style.display = 'flex'; el.style.opacity = '1';
  el.style.background = ok ? 'rgba(0,230,118,.12)' : 'rgba(255,77,77,.12)';
  el.style.border = `1px solid ${ok ? 'rgba(0,230,118,.3)' : 'rgba(255,77,77,.3)'}`;
  el.style.color = ok ? 'var(--g)' : 'var(--r)';
  clearTimeout(toastT);
  toastT = setTimeout(() => { el.style.opacity = '0'; setTimeout(() => el.style.display = 'none', 400); }, 4000);
}

// ── ESPN PROXY FETCH ──────────────────────────────────────────────────────────
function toESPNDate(labelDate) {
  const parts = labelDate.split('/');
  if (parts.length !== 3) return null;
  const [m, d, y] = parts;
  const year = parseInt(y) < 50 ? `20${y.padStart(2, '0')}` : `19${y.padStart(2, '0')}`;
  return `${year}${m.padStart(2, '0')}${d.padStart(2, '0')}`;
}

async function fetchScores(sport, dateStr) {
  try {
    const res = await fetch(`${PROXY_BASE}/api/scores?sport=${sport}&dates=${dateStr}`);
    if (!res.ok) return [];
    const data = await res.json();
    return data.games || [];
  } catch { return []; }
}

// ── TEAM MATCHING ─────────────────────────────────────────────────────────────
const ALIASES = {
  'celtics': 'boston celtics', 'lakers': 'los angeles lakers', 'warriors': 'golden state warriors',
  'nets': 'brooklyn nets', 'knicks': 'new york knicks', 'sixers': 'philadelphia 76ers',
  '76ers': 'philadelphia 76ers', 'bucks': 'milwaukee bucks', 'heat': 'miami heat',
  'bulls': 'chicago bulls', 'cavaliers': 'cleveland cavaliers', 'cavs': 'cleveland cavaliers',
  'pistons': 'detroit pistons', 'pacers': 'indiana pacers', 'raptors': 'toronto raptors',
  'hawks': 'atlanta hawks', 'hornets': 'charlotte hornets', 'magic': 'orlando magic',
  'wizards': 'washington wizards', 'nuggets': 'denver nuggets', 'wolves': 'minnesota timberwolves',
  'timberwolves': 'minnesota timberwolves', 'thunder': 'oklahoma city thunder',
  'blazers': 'portland trail blazers', 'jazz': 'utah jazz', 'kings': 'sacramento kings',
  'suns': 'phoenix suns', 'clippers': 'la clippers', 'spurs': 'san antonio spurs',
  'mavericks': 'dallas mavericks', 'mavs': 'dallas mavericks', 'rockets': 'houston rockets',
  'grizzlies': 'memphis grizzlies', 'pelicans': 'new orleans pelicans',
