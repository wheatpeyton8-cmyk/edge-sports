function getSigLabel(sig) { return { STRONG_BET: 'Strong bet', LEAN: 'Lean play', FADE: 'Fade', NEUTRAL: 'Neutral' }[sig] || 'Neutral'; }
function getConfColor(c) { return c >= 75 ? 'var(--g)' : c >= 63 ? 'var(--b)' : 'var(--a)'; }
function pcColor(v) { return v >= 55 ? 'kv-g' : v >= 50 ? 'kv-b' : 'kv-r'; }

