function resolveTeam(str) {
  if (!str) return '';
  let s = str.toLowerCase().trim()
    .replace(/^fade\s+\w+\s+[—-]\s+take\s+/i, '')
    .replace(/\s*([+-]\d{2,4}|ml)\s*$/gi, '')
    .replace(/\s+[+-]\d+(\.\d+)?$/, '')
    .trim();
  if (ALIASES[s]) return ALIASES[s];
  for (const [k, v] of Object.entries(ALIASES)) {
    if (s.includes(k)) return v;
  }
  return s;
}

function teamMatch(rec, espnName) {
  const r = resolveTeam(rec);
  const e = espnName.toLowerCase().trim();
  if (!r || !e) return false;
  if (r === e || e.includes(r) || r.includes(e)) return true;
  const rw = r.split(' ').filter(w => w.length > 3);
  const ew = e.split(' ').filter(w => w.length > 3);
  return rw.some(a => ew.some(b => a === b));
}

function computeResult(pick, g) {
  const rec = pick.rec || '';
  const recLow = rec.toLowerCase();
  const sp = parseFloat((pick.spread || '0').replace('+', '')) || 0;
  const ou = parseFloat(pick.ou || '0') || 0;
  const total = g.homeScore + g.awayScore;

  const homeHit = teamMatch(rec, g.homeTeam);
  const awayHit = teamMatch(rec, g.awayTeam);
  if (!homeHit && !awayHit) return null;

  if (recLow.includes('over') && ou > 0) return total > ou ? 'W' : total < ou ? 'L' : 'P';
  if (recLow.includes('under') && ou > 0) return total < ou ? 'W' : total > ou ? 'L' : 'P';

  const isML = /[+-]\d{2,3}/.test(rec) || recLow.endsWith(' ml') || recLow.includes(' ml ');

  if (homeHit) {
    if (isML) return g.homeScore > g.awayScore ? 'W' : g.homeScore < g.awayScore ? 'L' : 'P';
    const cover = (g.homeScore - g.awayScore) + sp;
    return cover > 0.5 ? 'W' : cover < -0.5 ? 'L' : 'P';
  }
  if (awayHit) {
    if (isML) return g.awayScore > g.homeScore ? 'W' : g.awayScore < g.homeScore ? 'L' : 'P';
    const cover = (g.awayScore - g.homeScore) - sp;
    return cover > 0.5 ? 'W' : cover < -0.5 ? 'L' : 'P';
  }
  return null;
}

// ── AUTO GRADE ────────────────────────────────────────────────────────────────
async function autoGrade() {
  const pend = picks.filter(p => !p.result || p.result === '');
  if (!pend.length) return 0;

  const sports = [...new Set(pend.map(p => p.sport))];
  const allDates = [...new Set([
    ...pend.map(p => toESPNDate(p.date)).filter(Boolean),
    TODAY_ISO.replace(/-/g, ''),
    YEST_ISO.replace(/-/g, ''),
    TWO_AGO_ISO.replace(/-/g, ''),
  ])];

  const scoreMap = {};
  await Promise.all(
    sports.flatMap(sport =>
      allDates.map(date =>
        fetchScores(sport, date).then(games => {
          if (!scoreMap[sport]) scoreMap[sport] = [];
          scoreMap[sport].push(...games.filter(g => g.completed));
        })
      )
    )
  );

  let n = 0;
  picks = picks.map(p => {
    if (p.result) return p;
    const games = scoreMap[p.sport] || [];
    for (const g of games) {
      const result = computeResult(p, g);
      if (result) {
        n++;
        return {
          ...p, result,
          finalScore: `${g.awayTeam} ${g.awayScore}-${g.homeScore} ${g.homeTeam}`,
          gradedAt: new Date().toISOString(),
        };
      }
    }
    return p;
  });
  return n;
}

