  const dotColor = { STRONG_BET: 'var(--g)', LEAN: 'var(--b)', FADE: 'var(--r)', NEUTRAL: 'var(--t3)' }[sig] || 'var(--t3)';
  return `<span class="sig-badge ${getSigBadgeClass(sig)}"><span class="sig-dot" style="background:${dotColor}"></span>${getSigLabel(sig)}</span>`;
}
