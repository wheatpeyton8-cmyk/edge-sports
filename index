function trackerView() {
  const w = picks.filter(p => p.result === 'W').length, l = picks.filter(p => p.result === 'L').length, pu = picks.filter(p => p.result === 'P').length;
  const tot = w + l + pu, pct = tot > 0 ? Math.round((w / tot) * 100) : 0;
  const units = picks.reduce((s, p) => { if (p.result === 'W') return s + (parseFloat(p.units) || 1); if (p.result === 'L') return s - (parseFloat(p.units) || 1); return s; }, 0);
  const pend = picks.filter(p => !p.result || p.result === '');

  const sigAcc = ['STRONG_BET', 'LEAN', 'FADE'].map(sg => {
    const ps = picks.filter(p => p.signal === sg && (p.result === 'W' || p.result === 'L'));
    const ww = ps.filter(p => p.result === 'W').length;
    return { sg, tot: ps.length, w: ww, pct: ps.length >= 3 ? Math.round((ww / ps.length) * 100) : null };
  }).filter(x => x.pct !== null);

  const spAcc = [...new Set(picks.map(p => p.sport).filter(Boolean))].map(sp => {
    const ps = picks.filter(p => p.sport === sp && (p.result === 'W' || p.result === 'L'));
    const ww = ps.filter(p => p.result === 'W').length;
    return { sp, tot: ps.length, w: ww, pct: ps.length >= 3 ? Math.round((ww / ps.length) * 100) : null };
  }).filter(s => s.pct !== null);

  const insight = () => {
    if (tot < 3) return 'Picks auto-log from Best bets. Refresh after games finish to auto-grade results.';
    const ins = [];
    sigAcc.forEach(l => {
      if (l.sg === 'STRONG_BET') ins.push(l.pct >= 60 ? `Strong bets hitting ${l.pct}% ✓` : `Strong bets at ${l.pct}% — tightening thresholds`);
      if (l.sg === 'LEAN' && l.pct >= 55) ins.push(`Lean plays at ${l.pct}% — consider sizing up`);
    });
    spAcc.forEach(s => { if (s.pct >= 62) ins.push(`${s.sp} model hot (${s.pct}%)`); else if (s.pct < 44) ins.push(`${s.sp} underperforming — recalibrating`); });
    return ins.filter(Boolean).join(' · ') || `${tot} settled. Model calibrating...`;
  };

  const lastGraded = picks.filter(p => p.gradedAt).sort((a, b) => new Date(b.gradedAt) - new Date(a.gradedAt))[0]?.gradedAt;
  const lgText = lastGraded ? new Date(lastGraded).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) : 'Not yet — hit refresh';

  const settled = picks.filter(p => p.result === 'W' || p.result === 'L' || p.result === 'P');
  const rows = [...picks].reverse().slice(0, 50).map(p => {
    const rc = p.result === 'W' ? 'r-win' : p.result === 'L' ? 'r-loss' : p.result === 'P' ? 'r-push' : 'r-pend';
    const ud = p.result === 'W' ? `+${p.units || 1}` : p.result === 'L' ? `-${p.units || 1}` : `${p.units || 1}`;
    return `<tr>
      <td style="color:var(--t2)">${p.date}</td>
      <td><span style="font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;background:rgba(255,255,255,.05);color:var(--t2)">${p.sport}</span></td>
      <td style="font-weight:700;color:var(--t1)">${p.rec}</td>
      <td style="color:var(--t2)">${p.spread || '—'}</td>
      <td class="${rc}">${p.result === 'W' ? '✓ Win' : p.result === 'L' ? '✗ Loss' : p.result === 'P' ? '─ Push' : 'Pending'}</td>
      <td style="font-size:10px;color:var(--t3);max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${p.finalScore || '—'}</td>
      <td style="font-weight:800;color:${p.result === 'W' ? 'var(--g)' : p.result === 'L' ? 'var(--r)' : 'var(--t3)'}">${ud}</td>
    </tr>`;
  }).join('');

  return `<div class="tracker-kpis">
    <div class="tkpi"><div class="tkpi-v" style="color:${pct >= 55 ? 'var(--g)' : pct >= 50 ? 'var(--b)' : 'var(--r)'}">${pct}%</div><div class="tkpi-l">Win rate</div></div>
    <div class="tkpi"><div class="tkpi-v kv-g">${w}</div><div class="tkpi-l">Wins</div></div>
    <div class="tkpi"><div class="tkpi-v kv-r">${l}</div><div class="tkpi-l">Losses</div></div>
    <div class="tkpi"><div class="tkpi-v kv-a">${pu}</div><div class="tkpi-l">Pushes</div></div>
    <div class="tkpi"><div class="tkpi-v" style="color:${units >= 0 ? 'var(--g)' : 'var(--r)'}">${units >= 0 ? '+' : ''}${units.toFixed(1)}</div><div class="tkpi-l">Units P/L</div></div>
  </div>
  <div class="last-graded"><span class="lg-dot" style="background:${lastGraded ? 'var(--g)' : 'var(--t3)'}"></span>Last graded: ${lgText}</div>
  <div class="model-insight"><strong>Model learning:</strong> ${insight()}</div>
  ${sigAcc.length ? secHd('Accuracy by signal') + '<div class="acc-grid">' + sigAcc.map(l => `<div class="acc-card">${sigBadge(l.sg)}<div class="acc-pct" style="color:${l.pct >= 55 ? 'var(--g)' : l.pct >= 50 ? 'var(--b)' : 'var(--r)'}">${l.pct}%</div><div class="acc-sub">${l.w}W · ${l.tot - l.w}L · ${l.tot} picks</div></div>`).join('') + '</div>' : ''}
  ${spAcc.length ? secHd('Accuracy by sport') + '<div class="acc-grid">' + spAcc.map(s => `<div class="acc-card"><div style="font-size:14px;font-weight:800;margin-bottom:7px">${s.sp}</div><div class="acc-pct" style="color:${s.pct >= 55 ? 'var(--g)' : s.pct >= 50 ? 'var(--b)' : 'var(--r)'}">${s.pct}%</div><div class="acc-sub">${s.w}W · ${s.tot - s.w}L · ${s.tot} picks</div></div>`).join('') + '</div>' : ''}
  ${settled.length >= 2 ? `<div class="chart-card"><div class="chart-hd">Units P/L over time<span class="chart-sub">${settled.length} settled picks</span></div><div class="chart-wrap"><canvas id="plc"></canvas></div></div>` : ''}
  ${pend.length ? secHd(`Pending (${pend.length}) — hit refresh after games end`) + pend.map(p => `<div class="pending-item"><div><div class="pi-pick">${p.rec}</div><div class="pi-meta">${p.sport} · ${p.date} · ${sigBadge(p.signal || 'NEUTRAL')}</div></div><div class="waiting"><span>Waiting for final score</span><span style="width:6px;height:6px;border-radius:50%;background:var(--a);animation:pulse 2s infinite;display:inline-block;flex-shrink:0"></span></div></div>`).join('') : ''}
  ${secHd('Pick history')}
  <div class="hist-wrap"><table class="hist-table"><thead><tr><th>Date</th><th>Sport</th><th>Pick</th><th>Spread</th><th>Result</th><th>Score</th><th>Units</th></tr></thead><tbody>${rows || '<tr><td colspan="7" style="text-align:center;padding:3rem;color:var(--t3)">No picks yet — refresh to load today\'s games</td></tr>'}</tbody></table></div>
  <div class="disc">Results auto-grade via ESPN public score API (/api/scores proxy). All best bets auto-log here daily. Model recalibrates as results accumulate. Not financial advice.</div>`;
}

// ── TAB RENDER ────────────────────────────────────────────────────────────────
function renderTabs() {
  const pend = picks.filter(p => !p.result || p.result === '').length;
  document.getElementById('tab-bar').innerHTML = TABS.map(t =>
    `<button class="tab-btn${activeTab === t.id ? ' on' : ''}" onclick="setTab('${t.id}')">
      <span class="tdot${t.live ? ' live' : ''}"></span>${t.label}
      ${t.id === 'tracker' && pend > 0 ? `<span class="tab-badge">${pend}</span>` : ''}
    </button>`
  ).join('');
}

function render() {
  const c = document.getElementById('content');
  c.style.animation = 'none';
  if (activeTab === 'best') c.innerHTML = bestView();
  else if (['nba', 'mlb', 'nhl'].includes(activeTab)) c.innerHTML = sportView(activeTab.toUpperCase());
  else if (['nfl', 'ncaaf', 'golf'].includes(activeTab)) c.innerHTML = offView(activeTab);
  else if (activeTab === 'tracker') c.innerHTML = trackerView();
  void c.offsetHeight;
  c.style.animation = 'fadeUp .25s ease';
  if (activeTab === 'tracker') setTimeout(renderPLChart, 80);
}

function renderPLChart() {
  const ctx = document.getElementById('plc'); if (!ctx) return;
  if (plChart) { try { plChart.destroy(); } catch {} }
  const settled = picks.filter(p => p.result === 'W' || p.result === 'L' || p.result === 'P');
  if (settled.length < 2) return;
  let run = 0; const labels = [], data = [];
  settled.forEach((p, i) => { if (p.result === 'W') run += parseFloat(p.units) || 1; else if (p.result === 'L') run -= parseFloat(p.units) || 1; labels.push(p.date || `#${i + 1}`); data.push(+run.toFixed(2)); });
  plChart = new Chart(ctx, { type: 'line', data: { labels, datasets: [{ data, borderColor: '#4d8bff', backgroundColor: 'rgba(77,139,255,.06)', tension: .35, pointRadius: 3, pointBackgroundColor: '#4d8bff', fill: true, borderWidth: 2 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { ticks: { font: { size: 9 }, color: '#4a5670', autoSkip: true, maxTicksLimit: 10 }, grid: { color: 'rgba(255,255,255,.04)' } }, y: { ticks: { font: { size: 9 }, color: '#4a5670' }, grid: { color: 'rgba(255,255,255,.04)' } } } } });
}

function setTab(t) { activeTab = t; renderTabs(); render(); }

// ── REFRESH ───────────────────────────────────────────────────────────────────
async function doRefresh() {
  if (isLoading) return;
  isLoading = true;
  const btn = document.getElementById('rfsh-btn');
  const sdot = document.getElementById('sdot');
  btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="animation:spin .8s linear infinite"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3"/></svg> Grading...`;
  btn.disabled = true;
  sdot.classList.add('loading');
  document.getElementById('ts').textContent = 'Checking scores...';

  try {
    // Seed today's picks
    const existing = loadS().picks || [];
    const existIds = new Set(existing.map(p => p.id));
    const fresh = SEED_PICKS.filter(p => !existIds.has(p.id)).map(p => ({ ...p, result: '', units: '1' }));
    picks = [...existing, ...fresh];
    saveS(picks);

    // Grade via ESPN proxy
    const n = await autoGrade();
    saveS(picks);
    renderTabs();
    render();
    if (activeTab === 'tracker') setTimeout(renderPLChart, 120);
    if (n > 0) toast(`${n} pick${n > 1 ? 's' : ''} graded ✓`, true);
    else toast('Scores checked — no new finals yet', true);
  } catch (e) {
    toast('Error — check console', false);
  } finally {
    btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3"/></svg> Refresh`;
    btn.disabled = false;
    sdot.classList.remove('loading');
    document.getElementById('ts').textContent = 'Updated ' + new Date().toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
    isLoading = false;
  }
}

// ── INIT ──────────────────────────────────────────────────────────────────────
document.getElementById('datestr').textContent = DATE_DISPLAY;
picks = loadS().picks || [];
if (!picks.some(p => p.date === TODAY_LABEL)) {
  picks = [...picks, ...SEED_PICKS.map(p => ({ ...p, result: '', units: '1' }))];
  saveS(picks);
}
renderTabs();
render();
setInterval(doRefresh, 120000);
</script>
</body>
</html>
